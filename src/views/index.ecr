<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#0a0a0f" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <title>Wavelength</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />

</head>
<body>
<div id="app">
  <header>
    <div class="logo">wave<span>length</span></div>
    <div class="header-right">
      <span id="track-count">— tracks</span>
      <input id="search" type="search" placeholder="filter…" autocomplete="off" />
      <button class="btn-icon" id="btn-rescan" title="Rescan library">⟳</button>
    </div>
  </header>

  <main>
    <div class="track-header">
      <div>#</div>
      <div>Title</div>
      <div class="col-artist col-toggle" id="toggle-artist">Artist</div>
      <div class="col-album col-toggle" id="toggle-album">Album</div>
      <div>Format</div>
    </div>
    <div id="track-list"></div>
  </main>

  <div id="player-bar">
    <div id="visualizer"><canvas id="vis-canvas"></canvas></div>
    <div class="player-top">
      <div class="now-playing">
        <div class="np-title" id="np-title">No track selected</div>
        <div class="np-sub" id="np-sub">—</div>
      </div>
      <div class="player-controls">
        <button class="ctrl" id="btn-shuffle" title="Shuffle">⇄</button>
        <button class="ctrl" id="btn-prev" title="Previous">⏮</button>
        <button class="ctrl play-pause" id="btn-play" title="Play/Pause">▶</button>
        <button class="ctrl" id="btn-next" title="Next">⏭</button>
        <button class="ctrl" id="btn-repeat" title="Repeat">↻</button>
      </div>
      <div class="volume-wrap">
        <span class="vol-icon">🔈</span>
        <input type="range" class="vol-bar" id="vol-bar" min="0" max="1" step="0.01" value="1" />
      </div>
    </div>
    <div class="seek-wrap">
      <span class="time-label" id="time-cur">0:00</span>
      <input type="range" class="seek-bar" id="seek-bar" min="0" max="1" step="0.001" value="0" />
      <span class="time-label right" id="time-dur">0:00</span>
    </div>
  </div>
</div>

<audio id="audio-el" preload="auto"></audio>

<script src="/js/app.js"></script>
</body>
</html>
